%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: CODE-Dialog_es
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: 0a78892ee6a7ac44eaef6f692257751c, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 1686814986240
    m_Localized: ...
    m_Metadata:
      m_Items: []
  - m_Id: 1644028891136
    m_Localized: Ah...
    m_Metadata:
      m_Items: []
  - m_Id: 259275231232
    m_Localized: "Qu\xE9 universo m\xE1s interesante. Nunca hab\xEDa visto algo tan
      inestable-"
    m_Metadata:
      m_Items: []
  - m_Id: 260965535744
    m_Localized: Oh? No puedes continuar?
    m_Metadata:
      m_Items: []
  - m_Id: 263586975744
    m_Localized: "Venga, eso deber\xEDa ayudarte."
    m_Metadata:
      m_Items: []
  - m_Id: 265453441024
    m_Localized: "Esta es la \xFAltima vez que te ayudar\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 420651077632
    m_Localized: "Qui\xE9n soy? Ni yo lo s\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 422211358720
    m_Localized: Ah, no te preocupes por eso.
    m_Metadata:
      m_Items: []
  - m_Id: 423234768896
    m_Localized: "Estoy seguro de que nos encontraremos alg\xFAn d\xEDa, simplemente
      no lo sabr\xE1s."
    m_Metadata:
      m_Items: []
  - m_Id: 475630014464
    m_Localized: "Pareces sorprendido de verme aqu\xED?"
    m_Metadata:
      m_Items: []
  - m_Id: 476238188544
    m_Localized: "Solo estoy recolectando informaci\xF3n, nada muy dr\xE1stico."
    m_Metadata:
      m_Items: []
  - m_Id: 476858945536
    m_Localized: "Bueno, este lugar parece muy inestable, as\xED que deber\xEDas
      irte antes de que sea muy tarde."
    m_Metadata:
      m_Items: []
  - m_Id: 536212541440
    m_Localized: "[Tu comunicaci\xF3n con el glifo desaparece\u2026]"
    m_Metadata:
      m_Items: []
  - m_Id: 1187487289344
    m_Localized: Al fin has llegado.
    m_Metadata:
      m_Items: []
  - m_Id: 1190188421120
    m_Localized: "(Lumi! De verdad, s\xED que te ha costado darles indicaciones aqu\xED.)"
    m_Metadata:
      m_Items: []
  - m_Id: 1191698370560
    m_Localized: "As\xED que\u2026 t\xFA! Vamos, te espera un reto."
    m_Metadata:
      m_Items: []
  - m_Id: 1267736907776
    m_Localized: CONTEMPLA!
    m_Metadata:
      m_Items: []
  - m_Id: 1268881952768
    m_Localized: "As\xED es! Buena suerte pasando, ya he ganado."
    m_Metadata:
      m_Items: []
  - m_Id: 1282156924928
    m_Localized: Injusto? Si, y lo siento, yo no hago las reglas.
    m_Metadata:
      m_Items: []
  - m_Id: 1438260531200
    m_Localized: QUE
    m_Metadata:
      m_Items: []
  - m_Id: 1438847733760
    m_Localized: "No deber\xEDa ser posible- C\xF3mo??"
    m_Metadata:
      m_Items: []
  - m_Id: 1439854366720
    m_Localized: "Esto es una estupidez! No me hab\xEDan avisado de esto."
    m_Metadata:
      m_Items: []
  - m_Id: 1530740740096
    m_Localized: "Fuego, entonces! Dale, m\xE1s fuego! M\xE1s! M\xE1s!"
    m_Metadata:
      m_Items: []
  - m_Id: 1564555218944
    m_Localized: ME QUEMO
    m_Metadata:
      m_Items: []
  - m_Id: 1565188558848
    m_Localized: DEMASIADO FUEGO, DEMASIADO FUEGO!!!!!!!
    m_Metadata:
      m_Items: []
  - m_Id: 1566019031040
    m_Localized: AHHHHHHHHHHHHHHHHHHHH-
    m_Metadata:
      m_Items: []
  - m_Id: 1687679012864
    m_Localized: "M-me has ganado\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1688551428096
    m_Localized: Pilla t-tu victoria y vete a otro lado.
    m_Metadata:
      m_Items: []
  - m_Id: 1689314791424
    m_Localized: "Fuera\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 1832722239488
    m_Localized: "[Decides seguir adelante, parece que est\xE1 calentito y c\xF3modo]."
    m_Metadata:
      m_Items: []
  - m_Id: 271917223383040
    m_Localized: Bienvenido a la trivia oficial de "A Directionless Cycle"!
    m_Metadata:
      m_Items: []
  - m_Id: 272072446185472
    m_Localized: He trabajado mucho en esto y he seleccionado solo las mejores preguntas.
    m_Metadata:
      m_Items: []
  - m_Id: 272073175994368
    m_Localized: Empecemos con algo simple.
    m_Metadata:
      m_Items: []
  - m_Id: 272073779974144
    m_Localized: "Cu\xE1ntos niveles principales hay entre W1 y el centro?"
    m_Metadata:
      m_Items: []
  - m_Id: 272280861151232
    m_Localized: "Pregunta trampa! He dicho \"entre\", as\xED que entre ellos."
    m_Metadata:
      m_Items: []
  - m_Id: 272281490296832
    m_Localized: Vamos a seguir...
    m_Metadata:
      m_Items: []
  - m_Id: 272282081693696
    m_Localized: "C\xF3mo se llama el nivel donde consigues el fragmento 4?"
    m_Metadata:
      m_Items: []
  - m_Id: 272474327617536
    m_Localized: Aha! Otra pregunta trampa, he preguntado por el nombre del nivel.
    m_Metadata:
      m_Items: []
  - m_Id: 272474914820096
    m_Localized: El cual... es...
    m_Metadata:
      m_Items: []
  - m_Id: 272475497828352
    m_Localized: "Te he pillado dos veces? Si es as\xED, lo siento mucho."
    m_Metadata:
      m_Items: []
  - m_Id: 272476156334080
    m_Localized: "Te prometo que no va a haber m\xE1s cosas raras a partir de ahora.
      Vamos!"
    m_Metadata:
      m_Items: []
  - m_Id: 272476760313856
    m_Localized: "Es el c\xF3digo \"CBA\" un c\xF3digo v\xE1lido que se puede utilizar
      en la pantalla principal?"
    m_Metadata:
      m_Items: []
  - m_Id: 272661276135424
    m_Localized: Uh...
    m_Metadata:
      m_Items: []
  - m_Id: 272670176448512
    m_Localized: "Esto no deber\xEDa..."
    m_Metadata:
      m_Items: []
  - m_Id: 272671283744768
    m_Localized: Fuego? Seguro que esto no puede empeorar.
    m_Metadata:
      m_Items: []
  - m_Id: 272787935727616
    m_Localized: "[Las grabaciones est\xE1n en llamas.]"
    m_Metadata:
      m_Items: []
  - m_Id: 272860048396288
    m_Localized: "Si! Mhm, ven por aqu\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 272909037867008
    m_Localized: "Qu\xE9 es- Espera, oh no-"
    m_Metadata:
      m_Items: []
  - m_Id: 272911613169664
    m_Localized: Mierda! Mis preguntas!
    m_Metadata:
      m_Items: []
  - m_Id: 272912221343744
    m_Localized: Uh... Por favor, no te salgas.
    m_Metadata:
      m_Items: []
  - m_Id: 273064394887168
    m_Localized: "Vale, est\xE1 bien. Ganas esta vez, supongo."
    m_Metadata:
      m_Items: []
  - m_Id: 273068446584832
    m_Localized: 'Vamos a seguir:'
    m_Metadata:
      m_Items: []
  - m_Id: 273070598262784
    m_Localized: "Cu\xE1les son las posiciones donde han estado las preguntas hasta
      ahora?"
    m_Metadata:
      m_Items: []
  - m_Id: 273334910717952
    m_Localized: "Mienten... Podr\xE1s resolverlo? Seguro..."
    m_Metadata:
      m_Items: []
  - m_Id: 273337242750976
    m_Localized: "T\xF3mate tu tiempo."
    m_Metadata:
      m_Items: []
  - m_Id: 273606403821568
    m_Localized: "Yo nunca mentir\xEDa. El de abajo miente."
    m_Metadata:
      m_Items: []
  - m_Id: 273655942746112
    m_Localized: "Claro que miento. Pero la pregunta tambi\xE9n."
    m_Metadata:
      m_Items: []
  - m_Id: 273765443440640
    m_Localized: Uh... uh!
    m_Metadata:
      m_Items: []
  - m_Id: 273766131306496
    m_Localized: No me estoy quedando sin ideas...
    m_Metadata:
      m_Items: []
  - m_Id: 273767284740096
    m_Localized: Elije un camino! Es un 50/50 verdad?
    m_Metadata:
      m_Items: []
  - m_Id: 273850277433344
    m_Localized: "Nuh, uh. M\xE1s vale que te choques contra la pared, NO te voy
      a ayudar."
    m_Metadata:
      m_Items: []
  - m_Id: 273888604983296
    m_Localized: "Eso, lo que ha dicho el de arriba. Date un golpe contra la pared
      o algo as\xED. Eso te ense\xF1ar\xE1."
    m_Metadata:
      m_Items: []
  - m_Id: 274010239799296
    m_Localized: Y... Para el gran final!
    m_Metadata:
      m_Items: []
  - m_Id: 274012534083584
    m_Localized: "Est\xE1s en la misma posici\xF3n X que la pantalla en la que empezaste?"
    m_Metadata:
      m_Items: []
  - m_Id: 274013091926016
    m_Localized: "T\xF3mate tu tiempo."
    m_Metadata:
      m_Items: []
  - m_Id: 718586813485056
    m_Localized: Woah.
    m_Metadata:
      m_Items: []
  - m_Id: 718587711066112
    m_Localized: Venga, a por todas.
    m_Metadata:
      m_Items: []
  - m_Id: 718510921748480
    m_Localized: "Te lo est\xE1s pasando bien?"
    m_Metadata:
      m_Items: []
  - m_Id: 718510326157312
    m_Localized: "Bot\xF3n conseguido!!!!"
    m_Metadata:
      m_Items: []
  - m_Id: 718460468465664
    m_Localized: "Hay un bot\xF3n sobre tu izquierda, m\xE1s o menos."
    m_Metadata:
      m_Items: []
  - m_Id: 718459889651712
    m_Localized: por cierto, no hay salidas en esta pantalla <3
    m_Metadata:
      m_Items: []
  - m_Id: 717999766114304
    m_Localized: por cierto,
    m_Metadata:
      m_Items: []
  - m_Id: 718000584003584
    m_Localized: NO lo siento.
    m_Metadata:
      m_Items: []
  - m_Id: 717995387260928
    m_Localized: El nivel entero es un laberinto.
    m_Metadata:
      m_Items: []
  - m_Id: 717996058349568
    m_Localized: Un laberinto invisible.
    m_Metadata:
      m_Items: []
  - m_Id: 717996783964160
    m_Localized: Son 12 pantallas combinadas, donde tienes que encontrar dos botones.
    m_Metadata:
      m_Items: []
  - m_Id: 717997908037632
    m_Localized: Y, al final, ves recto por el medio.
    m_Metadata:
      m_Items: []
  - m_Id: 717998780452864
    m_Localized: "No ganar\xE1s NADA al completar esto, solo es tortura."
    m_Metadata:
      m_Items: []
  - m_Id: 40853726998695936
    m_Localized: Hey!
    m_Metadata:
      m_Items: []
  - m_Id: 40860066936655872
    m_Localized: "Bienvenido a la \"dev room\". Aqu\xED, me escuchar\xE9is a m\xED
      (Lumi, el desarrollador) hablar un poco sobre el juego."
    m_Metadata:
      m_Items: []
  - m_Id: 40860085248987136
    m_Localized: "Has llegado sin querer? Te recomendar\xEDa que salgas y busques
      el camino despu\xE9s de acabar el juego!"
    m_Metadata:
      m_Items: []
  - m_Id: 40860096024154112
    m_Localized: "El c\xF3digo para este nivel est\xE1 muy bien escondido, pero a
      plena vista."
    m_Metadata:
      m_Items: []
  - m_Id: 40860107889840128
    m_Localized: Si no lo has encontrado, no te preocupes! Eres bienvenido igualmente.
    m_Metadata:
      m_Items: []
  - m_Id: 40860112268693504
    m_Localized: "As\xED que... Adelante!"
    m_Metadata:
      m_Items: []
  - m_Id: 52719719635095552
    m_Localized: "La versi\xF3n Gummi de ADC... La mejor versi\xF3n."
    m_Metadata:
      m_Items: []
  - m_Id: 52719775180263424
    m_Localized: Una reliquia del pasado- Vale, solo bromeo, tenemos Github.
    m_Metadata:
      m_Items: []
  - m_Id: 52719783484985344
    m_Localized: "ADC deber\xEDa haber sido un Sokoban simple para probar un poco
      el funcionamiento de Unity."
    m_Metadata:
      m_Items: []
  - m_Id: 52719788845305856
    m_Localized: "Y creo que sigue si\xE9ndolo, solo que ha crecido a algo m\xE1s
      personal de lo que pensaba."
    m_Metadata:
      m_Items: []
  - m_Id: 52719794327261184
    m_Localized: Eso ha sido principalmente por todo el tiempo que le he dedicado
      a esto.
    m_Metadata:
      m_Items: []
  - m_Id: 52719800522248192
    m_Localized: "El juego empez\xF3 a descontrolarse despu\xE9s de decidir que la
      habilidad de ciclar pudiera ir a otras pantallas."
    m_Metadata:
      m_Items: []
  - m_Id: 52719806335553536
    m_Localized: "Por qu\xE9??? El juego ya estaba acabado, en qu\xE9 mundo iba a
      hacer algo as\xED???"
    m_Metadata:
      m_Items: []
  - m_Id: 52719811402272768
    m_Localized: "Supongo que una parte de m\xED quer\xEDa hacer un juego m\xE1s
      grande. Y bueno, ha merecido la pena."
    m_Metadata:
      m_Items: []
  - m_Id: 52719817232355328
    m_Localized: "Despu\xE9s de incluir ciclar, y m\xFAltiples pantallas, creo que
      me llevo unos 3-4 meses para rehacerlo todo."
    m_Metadata:
      m_Items: []
  - m_Id: 52719823423148032
    m_Localized: "Y lo volver\xEDa a hacer todo otra vez! Fue muy divertido."
    m_Metadata:
      m_Items: []
  - m_Id: 52719829270007808
    m_Localized: "Espero que nadie te haya arruinado la sorpresa de la habilidad
      para ti. Les... moreder\xEDa."
    m_Metadata:
      m_Items: []
  - m_Id: 52720401725394944
    m_Localized: "...Bueno, no hay mucho que ver aqu\xED, vamos a seguir!"
    m_Metadata:
      m_Items: []
  - m_Id: 52725279080189952
    m_Localized: "Esta es la mayor\xEDa del diagrama de flujo del juego!"
    m_Metadata:
      m_Items: []
  - m_Id: 52725307404324864
    m_Localized: Ha estado bajo cambios intensos y constantes, dado que el juego
      no paraba de crecer.
    m_Metadata:
      m_Items: []
  - m_Id: 52725313905496064
    m_Localized: "Una de las cosas que ten\xEDa muchas, MUCHAS ganas de hacer era
      incluir secretos dentro de los niveles pista."
    m_Metadata:
      m_Items: []
  - m_Id: 52725318796054528
    m_Localized: "Desgraciadamente, no creo que hubiera quedado tan bien como yo
      quer\xEDa, as\xED que lo dej\xE9 como estaba."
    m_Metadata:
      m_Items: []
  - m_Id: 52725322424127488
    m_Localized: "Tambi\xE9n ten\xEDa que haber un \"nivel\" por artefacto, que ser\xEDa
      necesario para acceder al centro."
    m_Metadata:
      m_Items: []
  - m_Id: 52725327331463168
    m_Localized: ...Me estaba quedando sin ideas para niveles sobre este punto, jaja.
    m_Metadata:
      m_Items: []
  - m_Id: 52725358407061504
    m_Localized: "Finalmente, tambi\xE9n quer\xEDa esconder m\xE1s c\xF3digos a plena
      vista, como el que has utilizado para entrar aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 52725363779964928
    m_Localized: "Pero eso habr\xEDa sido muuuucho trabajo. As\xED que nos quedamos
      con esto."
    m_Metadata:
      m_Items: []
  - m_Id: 52727719259148288
    m_Localized: "Sab\xEDas?"
    m_Metadata:
      m_Items: []
  - m_Id: 52727738372591616
    m_Localized: "ADC ten\xEDa que ser mi proyecto final del instituto!"
    m_Metadata:
      m_Items: []
  - m_Id: 52727746173997056
    m_Localized: "De hecho, saqu\xE9 muy buena nota y recib\xED mucho feedback para
      expandir."
    m_Metadata:
      m_Items: []
  - m_Id: 52727754285780992
    m_Localized: "Eso s\xED, probablemente no inclu\xED tantas mec\xE1nicas como
      pensaba que estar\xEDan aqu\xED, pero eso es algo bueno."
    m_Metadata:
      m_Items: []
  - m_Id: 52727759159562240
    m_Localized: "Cr\xE9eme."
    m_Metadata:
      m_Items: []
  - m_Id: 52727764251447296
    m_Localized: "As\xED que, este proyecto deber\xEDa haber sido un mes solo, pero
      acab\xF3 siendo un proyecto muyyy largo."
    m_Metadata:
      m_Items: []
  - m_Id: 52727768680632320
    m_Localized: "Ampliaba y ampliaba hasta que ten\xEDa que quitar contenido! Era
      muy agotador."
    m_Metadata:
      m_Items: []
  - m_Id: 52727775198580736
    m_Localized: "Eso s\xED, estoy muy satisfecho."
    m_Metadata:
      m_Items: []
  - m_Id: 52729490564059136
    m_Localized: Lumi!
    m_Metadata:
      m_Items: []
  - m_Id: 52729516992368640
    m_Localized: La historia del juego original era sobre-
    m_Metadata:
      m_Items: []
  - m_Id: 52729523615174656
    m_Localized: "No, no era sobre Lumi. Pero a veces me gusta pensar que s\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 52729528954523648
    m_Localized: Era sobre "intentar que el universo no colapsara".
    m_Metadata:
      m_Items: []
  - m_Id: 52729532427407360
    m_Localized: Al parecer, en el universo del juego, era algo bastante normal.
    m_Metadata:
      m_Items: []
  - m_Id: 52729537330548736
    m_Localized: "Bastante gracioso c\xF3mo la historia cambi\xF3 a \"destruye lo
      que queda de un juego\", ir\xF3nico."
    m_Metadata:
      m_Items: []
  - m_Id: 52729542741200896
    m_Localized: "Te preguntas qui\xE9n es el desarrollador del juego de verdad?
      No lo s\xE9!"
    m_Metadata:
      m_Items: []
  - m_Id: 52729547371712512
    m_Localized: "Mi teor\xEDa es que Lumi lo hizo... Pero, oh bueno."
    m_Metadata:
      m_Items: []
  - m_Id: 52729551842840576
    m_Localized: "Estoy seguro de que acabar\xE1 saliendo a la luz alg\xFAn d\xEDa
      en el pr\xF3ximo juego que haga..."
    m_Metadata:
      m_Items: []
  - m_Id: 52729556322357248
    m_Localized: No exactamente el siguiente, simplemente alguno de ellos, estoy
      seguro!
    m_Metadata:
      m_Items: []
  - m_Id: 52729560726376448
    m_Localized: "Tampoco sab\xEDa qu\xE9 imagen utilizar aqu\xED, as\xED que...
      Lumi?"
    m_Metadata:
      m_Items: []
  - m_Id: 52729572352987136
    m_Localized: Vale, dile adios! Vamos a acabar esto.
    m_Metadata:
      m_Items: []
  - m_Id: 52731873826312192
    m_Localized: (Arte por @Holidalo/Twitter)
    m_Metadata:
      m_Items: []
  - m_Id: 52731967048912896
    m_Localized: "Antes de que te vayas, estoy muy agradecido a personas como t\xFA
      por jugar a mi juego."
    m_Metadata:
      m_Items: []
  - m_Id: 52731984061009920
    m_Localized: "Eres una de las pocas personas que muy probablemente han conseguido
      llegar hasta aqu\xED para ver esta sala."
    m_Metadata:
      m_Items: []
  - m_Id: 52731988502777856
    m_Localized: "Este viaje de \"dos\" a\xF1os ha sido muy especial para m\xED,
      y me alegro de haber podido compartirlo contigo."
    m_Metadata:
      m_Items: []
  - m_Id: 52731992135045120
    m_Localized: "Desde mi coraz\xF3n, gracias. Espero que te lo hayas pasado bien
      jugando a este est\xFApido proyecto hecho con pura pasi\xF3n."
    m_Metadata:
      m_Items: []
  - m_Id: 52732008446693376
    m_Localized: "Y para los que me pueden o\xEDr. Os escucho, tambi\xE9n."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
